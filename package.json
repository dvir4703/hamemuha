{
  "name": "hamemuha",
  "version": "0.1.0",
  "private": true,
  "description": "מערכת Windows לניהול והפעלת חידונים אינטראקטיביים בלייב",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "build:win": "pnpm build && electron-builder --win --x64 --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/assistant": "^5.2.9",
    "@fontsource-variable/rubik": "^5.2.8",
    "better-sqlite3": "^12.11.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.17",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0"
  }
}
